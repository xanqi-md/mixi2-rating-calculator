# OpenSkill Rating Bot - Environment Variables
# Copy this file to .env and fill in the values

# ============================================================
# REQUIRED: mixi2 Developer Platform credentials
# Get these from https://developer.mixi.social/
# ============================================================

# OAuth2 Client ID (from mixi2 Developer Console)
CLIENT_ID=your_client_id_here

# OAuth2 Client Secret (from mixi2 Developer Console)
CLIENT_SECRET=your_client_secret_here

# ============================================================
# REQUIRED: Admin user ID
# The mixi2 user ID of the person who will record match results
# This is the user_id shown in mixi2 profile (NOT @username)
# ============================================================
ADMIN_USER_ID=your_mixi2_user_id_here

# ============================================================
# OPTIONAL: mixi2 API endpoints (defaults are usually correct)
# ============================================================

# Token endpoint URL
TOKEN_URL=https://auth.mixi.social/oauth/token

# API server address (for posting/API calls)
API_ADDRESS=api.mixi.social:443

# Stream server address (for gRPC stream mode only)
STREAM_ADDRESS=stream.mixi.social:443

# ============================================================
# OPTIONAL: Webhook mode specific settings
# Only needed when running in webhook mode (cmd/webhook)
# ============================================================

# Ed25519 public key for signature verification (Base64 encoded)
# Get this from mixi2 Developer Console > Your App > Webhook settings
SIGNATURE_PUBLIC_KEY=

# HTTP port to listen on (default: 8080)
PORT=8080

# ============================================================
# OPTIONAL: Application settings
# ============================================================

# Path to SQLite database file
DB_PATH=./ratings.db
